<Application x:Class="QuickText.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Ui/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <tb:TaskbarIcon x:Key="Tray"
                        ToolTipText="QuickText"
                        IconSource="pack://application:,,,/Assets/quicktext.ico"
                        TrayMouseDoubleClick="OnTrayDoubleClick"
                        Visibility="Visible">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Style="{StaticResource DarkContextMenu}">
                    <ContextMenu.Resources>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource DarkMenuItem}"/>
                        <Style TargetType="Separator" BasedOn="{StaticResource DarkMenuSeparator}"/>
                    </ContextMenu.Resources>
                    <MenuItem Header="Open Search" Click="OnOpenSearch">
                        <MenuItem.Icon><TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.Accent}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Open Manager" Click="OnOpenManager">
                        <MenuItem.Icon><TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="New from clipboard" Click="OnNewFromClipboard">
                        <MenuItem.Icon><TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Settings" Click="OnSettings">
                        <MenuItem.Icon><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Pause expansion" Click="OnTogglePause">
                        <MenuItem.Icon><TextBlock Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExit">
                        <MenuItem.Icon><TextBlock Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
