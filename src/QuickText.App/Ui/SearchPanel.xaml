<Window x:Class="QuickText.App.Ui.SearchPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:QuickText.App"
        xmlns:pt="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="{Binding [App.Name], Source={x:Static app:LocProxy.Instance}}"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="Manual" Topmost="True" ShowInTaskbar="False"
        Width="680" SizeToContent="Height" MinWidth="480" MinHeight="340" ResizeMode="NoResize"
        Deactivated="OnDeactivated">
    <Window.Resources>
        <ContextMenu x:Key="RowMenu" Style="{StaticResource DarkContextMenu}">
            <ContextMenu.Resources>
                <Style TargetType="MenuItem" BasedOn="{StaticResource DarkMenuItem}"/>
                <Style TargetType="Separator" BasedOn="{StaticResource DarkMenuSeparator}"/>
            </ContextMenu.Resources>
            <MenuItem Header="{Binding [Ctx.Copy], Source={x:Static app:LocProxy.Instance}}" Click="OnCtxCopy">
                <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="{Binding [Search.Favorites], Source={x:Static app:LocProxy.Instance}}" Click="OnCtxFavorite">
                <MenuItem.Icon><TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.Star}"/></MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="{Binding [Ctx.Edit], Source={x:Static app:LocProxy.Instance}}" Click="OnCtxEdit">
                <MenuItem.Icon><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Brush.TextMuted}"/></MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </Window.Resources>
    <Border Margin="18" CornerRadius="16" Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="34" ShadowDepth="9" Direction="270" Opacity="0.5" Color="#FF000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="BodyRow" Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- input -->
            <Grid Grid.Row="0" Margin="20,18,20,13" Background="Transparent" MouseLeftButtonDown="OnInputDrag">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="17"
                           Foreground="{StaticResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,13,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="10,0,0,0">
                    <Button Style="{StaticResource GhostIconButton}" FontSize="14"
                            Content="&#xE710;" Click="OnNewSnippet"
                            ToolTip="{Binding [Search.Hint.New], Source={x:Static app:LocProxy.Instance}}"/>
                    <Button Style="{StaticResource GhostIconButton}" FontSize="14" Margin="4,0,0,0"
                            Content="&#xE8F1;" Click="OnOpenManager"
                            ToolTip="{Binding [Tray.OpenManager], Source={x:Static app:LocProxy.Instance}}"/>
                    <Button Style="{StaticResource GhostIconButton}" FontSize="14" Margin="4,0,0,0"
                            Content="&#xE713;" Click="OnOpenSettings"
                            ToolTip="{Binding [Tray.Settings], Source={x:Static app:LocProxy.Instance}}"/>
                    <Button x:Name="PinButton" Style="{StaticResource GhostIconButton}" FontSize="14"
                            Content="&#xE718;" Margin="4,0,0,0" Click="OnTogglePin"
                            ToolTip="{Binding [Search.KeepOpen], Source={x:Static app:LocProxy.Instance}}"/>
                </StackPanel>
                <Grid Grid.Column="1">
                    <TextBox x:Name="Query" Background="Transparent" BorderThickness="0" Padding="0"
                             FontFamily="{StaticResource Font.Ui}" FontSize="19"
                             Foreground="{StaticResource Brush.TextPrimary}"
                             CaretBrush="{StaticResource Brush.Accent}"
                             SelectionBrush="{StaticResource Brush.Accent}"
                             VerticalContentAlignment="Center" TextChanged="OnQueryChanged"/>
                    <TextBlock Text="{Binding [Search.Placeholder], Source={x:Static app:LocProxy.Instance}}"
                               FontFamily="{StaticResource Font.Ui}" FontSize="19"
                               Foreground="{StaticResource Brush.TextFaint}" IsHitTestVisible="False"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=Query}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="{StaticResource Brush.Divider}" Margin="16,0"/>

            <!-- body: browse (two-pane) / search results / empty -->
            <Grid Grid.Row="2" Margin="8,7,8,7">
                <!-- browse mode: category rail | snippets -->
                <Grid x:Name="BrowseView">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="182"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ListBox x:Name="CategoryRail" Grid.Column="0" Background="Transparent" BorderThickness="0"
                             MaxHeight="404" HorizontalContentAlignment="Stretch"
                             VirtualizingPanel.IsVirtualizing="False" ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemTemplate="{StaticResource CategoryRowTemplate}"
                             ItemContainerStyle="{StaticResource CategoryRailItem}"
                             SelectionChanged="OnCategoryChanged"/>
                    <Border Grid.Column="1" Background="{StaticResource Brush.Divider}" Margin="0,3"/>
                    <ListBox x:Name="BrowseList" Grid.Column="2" Background="Transparent" BorderThickness="0" Margin="7,0,0,0"
                             MaxHeight="404" HorizontalContentAlignment="Stretch" AlternationCount="99"
                             VirtualizingPanel.IsVirtualizing="False" ScrollViewer.CanContentScroll="False"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemTemplate="{StaticResource SnippetRowTemplate}"
                             ItemContainerStyle="{StaticResource SnippetRowContainer}"
                             ContextMenu="{StaticResource RowMenu}"
                             PreviewMouseRightButtonDown="OnRowRightClick"
                             SelectionChanged="OnSnippetSelectionChanged"
                             MouseLeftButtonUp="OnListClick"
                             MouseDoubleClick="OnResultsDoubleClick"/>
                </Grid>

                <!-- search mode: flat ranked results -->
                <ListBox x:Name="Results" Visibility="Collapsed" Background="Transparent" BorderThickness="0" MaxHeight="404"
                         HorizontalContentAlignment="Stretch" AlternationCount="99"
                         VirtualizingPanel.IsVirtualizing="False" ScrollViewer.CanContentScroll="False"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemTemplate="{StaticResource SnippetRowTemplate}"
                         ItemContainerStyle="{StaticResource SnippetRowContainer}"
                         ContextMenu="{StaticResource RowMenu}"
                         PreviewMouseRightButtonDown="OnRowRightClick"
                         SelectionChanged="OnSnippetSelectionChanged"
                         MouseLeftButtonUp="OnListClick"
                         MouseDoubleClick="OnResultsDoubleClick"/>

                <!-- empty state -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed" MinHeight="118"
                            VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20,16">
                    <TextBlock x:Name="EmptyText" HorizontalAlignment="Center"
                               FontFamily="{StaticResource Font.Ui}" FontSize="13.5"
                               Foreground="{StaticResource Brush.TextMuted}"/>
                    <TextBlock x:Name="EmptySub" HorizontalAlignment="Center" Margin="0,5,0,0"
                               FontFamily="{StaticResource Font.Ui}" FontSize="11.5"
                               Foreground="{StaticResource Brush.TextFaint}"/>
                    <Button x:Name="CreateButton" Visibility="Collapsed" HorizontalAlignment="Center" Margin="0,14,0,0"
                            Style="{StaticResource DarkButtonPrimary}" Padding="16,6" FontSize="12.5"
                            Click="OnCreateFromQuery"/>
                </StackPanel>
            </Grid>

            <!-- full-text preview of the selected snippet -->
            <Border x:Name="PreviewPane" Grid.Row="3" Visibility="Collapsed" Margin="20,2,20,8"
                    BorderBrush="{StaticResource Brush.Divider}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <TextBlock x:Name="PreviewText" TextWrapping="Wrap" FontFamily="{StaticResource Font.Ui}"
                                   FontSize="13" LineHeight="19" Foreground="{StaticResource Brush.TextMuted}"/>
                        <Image x:Name="PreviewImage" Stretch="Uniform" MaxHeight="138" HorizontalAlignment="Left" Visibility="Collapsed"/>
                    </Grid>
                </ScrollViewer>
            </Border>

            <!-- footer -->
            <Border Grid.Row="4" Background="{StaticResource Brush.FooterBg}" CornerRadius="0,0,15,15" Padding="18,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Style="{StaticResource HintKey}"><TextBlock Text="↑↓" Style="{StaticResource HintKeyText}"/></Border>
                            <TextBlock Text="{Binding [Search.Hint.Nav], Source={x:Static app:LocProxy.Instance}}" Style="{StaticResource HintLabel}"/>
                        </StackPanel>
                        <StackPanel x:Name="HintCat" Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Style="{StaticResource HintKey}"><TextBlock Text="←→" Style="{StaticResource HintKeyText}"/></Border>
                            <TextBlock Text="{Binding [Search.Hint.SwitchCat], Source={x:Static app:LocProxy.Instance}}" Style="{StaticResource HintLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Border Style="{StaticResource HintKey}"><TextBlock Text="↵" Style="{StaticResource HintKeyText}"/></Border>
                            <TextBlock Text="{Binding [Search.Hint.Send], Source={x:Static app:LocProxy.Instance}}" Style="{StaticResource HintLabel}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource HintKey}"><TextBlock Text="esc" Style="{StaticResource HintKeyText}"/></Border>
                            <TextBlock Text="{Binding [Search.Hint.Close], Source={x:Static app:LocProxy.Instance}}" Style="{StaticResource HintLabel}"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="CountText" HorizontalAlignment="Right" VerticalAlignment="Center"
                               FontFamily="{StaticResource Font.Ui}" FontSize="11.5"
                               Foreground="{StaticResource Brush.TextFaint}"/>
                </Grid>
            </Border>

            <!-- resize grip -->
            <pt:Thumb Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="18" Height="18"
                      Margin="0,0,3,3" Cursor="SizeNWSE" DragDelta="OnResizeDrag">
                <pt:Thumb.Template>
                    <ControlTemplate TargetType="pt:Thumb">
                        <Grid Background="Transparent">
                            <Path Data="M 16,5 L 16,16 L 5,16 Z" Fill="{StaticResource Brush.TextFaint}" Opacity="0.6"/>
                        </Grid>
                    </ControlTemplate>
                </pt:Thumb.Template>
            </pt:Thumb>
        </Grid>
    </Border>
</Window>
