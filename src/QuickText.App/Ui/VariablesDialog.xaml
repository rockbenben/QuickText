<Window x:Class="QuickText.App.Ui.VariablesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen" ShowInTaskbar="False" Topmost="True"
        Background="{StaticResource Brush.WinBg}" FontFamily="{StaticResource Font.Ui}">
    <StackPanel Margin="24,20,24,20">
        <TextBlock x:Name="TitleText" Foreground="{StaticResource Brush.TextPrimary}"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>
        <ItemsControl x:Name="Fields">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Text="{Binding Name, StringFormat={}{{{0}}}}" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}" FontSize="14"
                                 Visibility="{Binding TextBoxVis}"/>
                        <ComboBox IsEditable="True" FontSize="14" Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding Options}"
                                  Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                  Visibility="{Binding ComboVis}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button x:Name="CancelButton" Style="{StaticResource DarkButton}" MinWidth="84" Padding="16,7" Margin="0,0,10,0" Click="OnCancel"/>
            <Button x:Name="OkButton" Style="{StaticResource DarkButtonPrimary}" MinWidth="84" Padding="16,7" Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
