<Window x:Class="QuickText.App.Ui.TrashDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="440" ResizeMode="CanResize" MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        Background="{StaticResource Brush.WinBg}" FontFamily="{StaticResource Font.Ui}">
    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.TextPrimary}"/>
        <TextBlock Grid.Row="1" x:Name="HintText" FontSize="11.5" Margin="0,4,0,10"
                   Foreground="{StaticResource Brush.TextFaint}" TextWrapping="Wrap"/>

        <ListBox Grid.Row="2" x:Name="Items" SelectionMode="Extended"
                 Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource DarkListItem}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2,3" ToolTip="{Binding Tip}">
                        <TextBlock Text="{Binding Name}" FontSize="13.5" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Text="{Binding Preview}" FontSize="12" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis" FontFamily="{StaticResource Font.Mono}"
                                   Foreground="{StaticResource Brush.TextMuted}"/>
                        <TextBlock Text="{Binding Detail}" FontSize="11.5" Margin="0,2,0,0"
                                   Foreground="{StaticResource Brush.TextFaint}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <TextBlock Grid.Row="2" x:Name="EmptyText" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontSize="13" Foreground="{StaticResource Brush.TextFaint}" Visibility="Collapsed"/>

        <DockPanel Grid.Row="3" Margin="0,14,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Left" x:Name="RestoreButton" Style="{StaticResource DarkButtonPrimary}"
                    Padding="14,7" Click="OnRestore"/>
            <Button DockPanel.Dock="Left" x:Name="DeleteButton" Style="{StaticResource DarkButton}"
                    Padding="14,7" Margin="8,0,0,0" Click="OnDeleteForever"/>
            <Button DockPanel.Dock="Left" x:Name="EmptyButton" Style="{StaticResource DarkButton}"
                    Padding="14,7" Margin="8,0,0,0" Click="OnEmptyTrash"/>
            <Button DockPanel.Dock="Right" x:Name="CloseButton" Style="{StaticResource DarkButton}"
                    Padding="14,7" Click="OnClose"/>
        </DockPanel>
    </Grid>
</Window>
