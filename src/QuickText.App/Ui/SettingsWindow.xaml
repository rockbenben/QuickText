<Window x:Class="QuickText.App.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:QuickText.App"
        Title="{Binding [App.Name], Source={x:Static app:LocProxy.Instance}}"
        Width="860" SizeToContent="Height" ResizeMode="NoResize"
        Background="{StaticResource Brush.WinBg}" FontFamily="{StaticResource Font.Ui}">
    <DockPanel Margin="24,16,24,18">

        <!-- title: 设置 + brand caret (the "text▮" mark), version stamp on the right -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding [Tray.Settings], Source={x:Static app:LocProxy.Instance}}"
                           FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource Brush.TextPrimary}"/>
                <!-- brand motif: the text-insertion caret from the "text▮" mark -->
                <Border Width="3" Height="21" CornerRadius="1.5" Margin="8,2,0,0" VerticalAlignment="Center"
                        Background="{StaticResource Brush.Amber}"/>
            </StackPanel>
            <TextBlock x:Name="VersionText" HorizontalAlignment="Right" VerticalAlignment="Center"
                       FontFamily="{StaticResource Font.Mono}" FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}"/>
        </Grid>

        <!-- footer: project link (left) + Save (right), docked so both stay visible. TabIndex keeps
             the fields ahead of Save in the tab order (the bottom-docked footer is declared before
             the ScrollViewer). -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <!-- GitHub mark → project home; hover brightens it (a Button, not a Hyperlink, so the
                 embedded vector reliably receives the click). -->
            <Button Click="OnOpenRepo" HorizontalAlignment="Left" VerticalAlignment="Center"
                    Cursor="Hand" ToolTip="https://github.com/rockbenben/QuickText">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="1">
                            <Path x:Name="mark" Width="17" Height="17" Stretch="Uniform"
                                  Fill="{StaticResource Brush.TextFaint}"
                                  Data="F1 M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="mark" Property="Fill" Value="{StaticResource Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button TabIndex="1" Content="{Binding [Manager.Save], Source={x:Static app:LocProxy.Instance}}"
                    HorizontalAlignment="Right" MinWidth="104" Padding="18,9"
                    Style="{StaticResource DarkButtonPrimary}" Click="OnSave"/>
        </Grid>

        <!-- scrollable card area: on a short / high-DPI screen this scrolls instead of pushing the
             Save button off-screen under the taskbar (the window height is capped to the work area) -->
        <ScrollViewer TabIndex="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="0,0,2,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ============ left column ============ -->
            <StackPanel Grid.Column="0">

                <!-- card · 呼出 -->
                <Border Style="{StaticResource SetCard}">
                    <StackPanel>
                        <ContentControl Margin="0,0,0,10" Style="{StaticResource SetHeader}"
                                        Content="{Binding [Settings.SectionSummon], Source={x:Static app:LocProxy.Instance}}"/>

                        <!-- summon method: key combo OR tap a lone modifier — mutually exclusive -->
                        <TextBlock Text="{Binding [Settings.SummonMode], Source={x:Static app:LocProxy.Instance}}"
                                   Style="{StaticResource FieldLabel}"/>
                        <WrapPanel x:Name="SummonModePanel">
                            <RadioButton GroupName="SummonMode" Style="{StaticResource ChipToggle}" Tag="hotkey" Checked="OnSummonModeChecked"
                                         Content="{Binding [Settings.SummonModeHotkey], Source={x:Static app:LocProxy.Instance}}"/>
                            <RadioButton GroupName="SummonMode" Style="{StaticResource ChipToggle}" Tag="tap" Checked="OnSummonModeChecked"
                                         Content="{Binding [Settings.SummonModeTap], Source={x:Static app:LocProxy.Instance}}"/>
                        </WrapPanel>

                        <!-- mode: key combo -->
                        <StackPanel x:Name="HotkeyModePanel" Margin="0,6,0,0">
                            <Border x:Name="HotkeyBox" Background="{StaticResource Brush.InputBg}" BorderBrush="{StaticResource Brush.InputBorder}"
                                    BorderThickness="1" CornerRadius="7" Padding="12,9" Focusable="True" Cursor="Hand"
                                    MouseLeftButtonDown="OnHotkeyBoxClick" PreviewKeyDown="OnHotkeyKeyDown"
                                    LostKeyboardFocus="OnHotkeyLostFocus">
                                <TextBlock x:Name="HotkeyText" FontFamily="{StaticResource Font.Ui}" FontSize="14"
                                           Foreground="{StaticResource Brush.TextPrimary}"/>
                            </Border>
                            <TextBlock Text="{Binding [Settings.HotkeyHint], Source={x:Static app:LocProxy.Instance}}"
                                       FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="2,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- mode: tap a lone modifier (RegisterHotKey can't do a single modifier) -->
                        <StackPanel x:Name="TapModePanel" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="SummonTapBox" Background="{StaticResource Brush.InputBg}" BorderBrush="{StaticResource Brush.InputBorder}"
                                        BorderThickness="1" CornerRadius="7" Padding="12,9" Focusable="True" Cursor="Hand" MinWidth="88"
                                        MouseLeftButtonDown="OnSummonTapClick" PreviewKeyDown="OnSummonTapKeyDown" LostKeyboardFocus="OnSummonTapLostFocus">
                                    <TextBlock x:Name="SummonTapText" FontFamily="{StaticResource Font.Ui}" FontSize="14"
                                               Foreground="{StaticResource Brush.TextPrimary}"/>
                                </Border>
                                <CheckBox x:Name="SummonTapDouble" Style="{StaticResource DarkCheckBox}" VerticalAlignment="Center" Margin="12,0,0,0"
                                          Content="{Binding [Settings.SummonTapDouble], Source={x:Static app:LocProxy.Instance}}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding [Settings.SummonTapHint], Source={x:Static app:LocProxy.Instance}}"
                                       FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="2,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <TextBlock Text="{Binding [Settings.CaptureHotkey], Source={x:Static app:LocProxy.Instance}}"
                                   Style="{StaticResource FieldLabel}" Margin="2,12,0,6"/>
                        <Border x:Name="CaptureBox" Background="{StaticResource Brush.InputBg}" BorderBrush="{StaticResource Brush.InputBorder}"
                                BorderThickness="1" CornerRadius="7" Padding="12,9" Focusable="True" Cursor="Hand"
                                MouseLeftButtonDown="OnCaptureBoxClick" PreviewKeyDown="OnHotkeyKeyDown"
                                LostKeyboardFocus="OnHotkeyLostFocus">
                            <TextBlock x:Name="CaptureText" FontFamily="{StaticResource Font.Ui}" FontSize="14"
                                       Foreground="{StaticResource Brush.TextPrimary}"/>
                        </Border>
                        <TextBlock Text="{Binding [Settings.CaptureHotkeyHint], Source={x:Static app:LocProxy.Instance}}"
                                   FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="2,6,0,0" TextWrapping="Wrap"/>

                        <TextBlock Text="{Binding [Settings.PanelPlacement], Source={x:Static app:LocProxy.Instance}}"
                                   Style="{StaticResource FieldLabel}" Margin="2,12,0,6"/>
                        <WrapPanel x:Name="PlacementPanel">
                            <RadioButton GroupName="Place" Style="{StaticResource ChipToggle}" Tag="window" Checked="OnPlacementChecked"
                                         Content="{Binding [Settings.PlaceWindow], Source={x:Static app:LocProxy.Instance}}"/>
                            <RadioButton GroupName="Place" Style="{StaticResource ChipToggle}" Tag="caret" Checked="OnPlacementChecked"
                                         Content="{Binding [Settings.PlaceCaret], Source={x:Static app:LocProxy.Instance}}"/>
                            <RadioButton GroupName="Place" Style="{StaticResource ChipToggle}" Tag="fixed" Checked="OnPlacementChecked"
                                         Content="{Binding [Settings.PlaceFixed], Source={x:Static app:LocProxy.Instance}}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- card · 缩写 -->
                <Border Style="{StaticResource SetCard}" Margin="0,10,0,0">
                    <StackPanel>
                        <ContentControl Margin="0,0,0,10" Style="{StaticResource SetHeader}"
                                        Content="{Binding [Settings.SectionAbbr], Source={x:Static app:LocProxy.Instance}}"/>
                        <CheckBox x:Name="AbbrEnabled" Style="{StaticResource DarkCheckBox}"
                                  Content="{Binding [Settings.AbbrEnabled], Source={x:Static app:LocProxy.Instance}}"/>
                        <StackPanel IsEnabled="{Binding IsChecked, ElementName=AbbrEnabled}" Margin="0,12,0,0">
                            <TextBlock Text="{Binding [Settings.AbbrPrefix], Source={x:Static app:LocProxy.Instance}}"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="AbbrPrefixBox" Style="{StaticResource DarkTextBox}" HorizontalAlignment="Left" Width="90"
                                     FontFamily="{StaticResource Font.Mono}" FontSize="14"/>
                            <TextBlock Text="{Binding [Settings.AbbrPrefixHint], Source={x:Static app:LocProxy.Instance}}"
                                       FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="2,6,0,14" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding [Settings.AbbrBlacklist], Source={x:Static app:LocProxy.Instance}}"
                                       Style="{StaticResource FieldLabel}"/>
                            <TextBox x:Name="AbbrBlacklist" Style="{StaticResource DarkTextBox}"
                                     FontFamily="{StaticResource Font.Mono}" FontSize="12"/>
                            <TextBlock Text="{Binding [Settings.AbbrBlacklistHint], Source={x:Static app:LocProxy.Instance}}"
                                       FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="2,6,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ============ right column ============ -->
            <StackPanel Grid.Column="2">

                <!-- card · 输出 -->
                <Border Style="{StaticResource SetCard}">
                    <StackPanel>
                        <ContentControl Margin="0,0,0,10" Style="{StaticResource SetHeader}"
                                        Content="{Binding [Settings.SectionOutput], Source={x:Static app:LocProxy.Instance}}"/>
                        <WrapPanel x:Name="OutputPanel">
                            <RadioButton GroupName="Output" Style="{StaticResource ChipToggle}" Tag="paste" Checked="OnOutputChecked"
                                         Content="{Binding [Settings.OutputPaste], Source={x:Static app:LocProxy.Instance}}"/>
                            <RadioButton GroupName="Output" Style="{StaticResource ChipToggle}" Tag="clip" Checked="OnOutputChecked"
                                         Content="{Binding [Settings.OutputClipboard], Source={x:Static app:LocProxy.Instance}}"/>
                        </WrapPanel>
                        <CheckBox x:Name="AutoSend" Style="{StaticResource DarkCheckBox}" Margin="0,4,0,0"
                                  Content="{Binding [Settings.AutoSend], Source={x:Static app:LocProxy.Instance}}"/>
                        <CheckBox x:Name="ClickToSend" Style="{StaticResource DarkCheckBox}" Margin="0,9,0,0"
                                  Content="{Binding [Settings.ClickToSend], Source={x:Static app:LocProxy.Instance}}"/>
                        <TextBlock Text="{Binding [Settings.ClickToSendHint], Source={x:Static app:LocProxy.Instance}}"
                                   FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="24,3,0,0" TextWrapping="Wrap"/>
                        <CheckBox x:Name="RestoreClipboard" Style="{StaticResource DarkCheckBox}" Margin="0,9,0,0"
                                  Content="{Binding [Settings.RestoreClipboard], Source={x:Static app:LocProxy.Instance}}"/>
                        <TextBlock Text="{Binding [Settings.RestoreClipboardHint], Source={x:Static app:LocProxy.Instance}}"
                                   FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="24,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- card · 数据 -->
                <Border Style="{StaticResource SetCard}" Margin="0,10,0,0">
                    <StackPanel>
                        <ContentControl Margin="0,0,0,10" Style="{StaticResource SetHeader}"
                                        Content="{Binding [Settings.SectionData], Source={x:Static app:LocProxy.Instance}}"/>
                        <TextBlock Text="{Binding [Settings.DataFolder], Source={x:Static app:LocProxy.Instance}}" Style="{StaticResource FieldLabel}"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="…" Width="38" Margin="8,0,0,0" Style="{StaticResource DarkButton}" Click="OnBrowse"/>
                            <Button DockPanel.Dock="Right" Width="38" Margin="8,0,0,0" Style="{StaticResource DarkButton}" Click="OnOpenFolder"
                                    ToolTip="{Binding [Settings.OpenFolder], Source={x:Static app:LocProxy.Instance}}">
                                <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                            </Button>
                            <TextBox x:Name="DataFolder" Style="{StaticResource DarkTextBox}"/>
                        </DockPanel>
                        <!-- WrapPanel so the three buttons wrap instead of overflowing the card when
                             the labels are longer (English / 日本語) or the column is narrow. -->
                        <WrapPanel Margin="0,10,0,-8">
                            <Button Style="{StaticResource DarkButton}" Padding="12,6" Margin="0,0,8,8"
                                    Content="{Binding [Settings.ExportBackup], Source={x:Static app:LocProxy.Instance}}"
                                    Click="OnExportBackup"/>
                            <Button Style="{StaticResource DarkButton}" Padding="12,6" Margin="0,0,8,8"
                                    Content="{Binding [Settings.ImportBackup], Source={x:Static app:LocProxy.Instance}}"
                                    Click="OnImportBackup"/>
                            <Button Style="{StaticResource DarkButton}" Padding="12,6" Margin="0,0,0,8"
                                    Content="{Binding [Settings.OpenBackups], Source={x:Static app:LocProxy.Instance}}"
                                    Click="OnOpenBackups"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding [Settings.AutoBackupHint], Source={x:Static app:LocProxy.Instance}}"
                                   FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="2,8,0,0" TextWrapping="Wrap"/>

                        <!-- portable mode: the toggle creates/removes the marker file for the user
                             (it can't be a plain saved setting — it decides where settings.json lives) -->
                        <CheckBox x:Name="PortableMode" Style="{StaticResource DarkCheckBox}" Margin="0,12,0,0"
                                  Click="OnPortableToggle"
                                  Content="{Binding [Settings.Portable], Source={x:Static app:LocProxy.Instance}}"/>
                        <TextBlock Text="{Binding [Settings.PortableHint], Source={x:Static app:LocProxy.Instance}}"
                                   FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="24,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- card · 通用 -->
                <Border Style="{StaticResource SetCard}" Margin="0,10,0,0">
                    <StackPanel>
                        <ContentControl Margin="0,0,0,10" Style="{StaticResource SetHeader}"
                                        Content="{Binding [Settings.SectionGeneral], Source={x:Static app:LocProxy.Instance}}"/>
                        <TextBlock Text="{Binding [Settings.Language], Source={x:Static app:LocProxy.Instance}}" Style="{StaticResource FieldLabel}"/>
                        <!-- 18 UI languages + follow-system: a dropdown keeps the card compact.
                             Items (code + native name) are supplied in code so the dark item style applies. -->
                        <ComboBox x:Name="LangCombo" Style="{StaticResource DarkComboBox}"
                                  SelectedValuePath="Code" HorizontalAlignment="Left" MinWidth="190">
                            <!-- An explicit ItemTemplate (not DisplayMemberPath): the dark template's
                                 selection box renders via SelectionBoxItemTemplate, which DisplayMemberPath
                                 does NOT populate — so the closed box would otherwise show the record's
                                 ToString() ("LangItem { … }") instead of the language name. -->
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <CheckBox x:Name="Autostart" Style="{StaticResource DarkCheckBox}" Margin="0,4,0,0"
                                  Content="{Binding [Tray.Autostart], Source={x:Static app:LocProxy.Instance}}"/>

                        <!-- opt-in update check: OFF by default; the only feature that goes online -->
                        <CheckBox x:Name="CheckUpdates" Style="{StaticResource DarkCheckBox}" Margin="0,9,0,0"
                                  Content="{Binding [Settings.CheckUpdates], Source={x:Static app:LocProxy.Instance}}"/>
                        <TextBlock Text="{Binding [Settings.CheckUpdatesHint], Source={x:Static app:LocProxy.Instance}}"
                                   FontSize="11.5" Foreground="{StaticResource Brush.TextFaint}" Margin="24,3,0,0" TextWrapping="Wrap"/>
                        <Button HorizontalAlignment="Left" Style="{StaticResource DarkButton}" Padding="12,6" Margin="24,8,0,0"
                                Content="{Binding [Settings.CheckNow], Source={x:Static app:LocProxy.Instance}}" Click="OnCheckUpdatesNow"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
